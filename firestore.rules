rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId
    // Fields:
    //   - uid: string (required)
    //   - displayName: string (required)
    //   - email: string (optional)
    //   - photoURL: string (optional)
    //   - coins: number (required)
    //   - highScore: number (optional)
    //   - lastSaved: string (optional)
    //
    // Collection: gardens
    // Document ID: userId
    // Fields:
    //   - uid: string (required)
    //   - plots: list (required)
    //   - kangals: number (required)
    //
    // Collection: leaderboard
    // Document ID: userId
    // Fields:
    //   - uid: string (required)
    //   - displayName: string (required)
    //   - score: number (required)
    //   - photoURL: string (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'coins']) &&
             data.uid is string &&
             data.displayName is string && data.displayName.size() < 100 &&
             data.coins is number && data.coins >= 0;
    }

    function isValidGarden(data) {
      return data.keys().hasAll(['uid', 'plots', 'kangals']) &&
             data.uid is string &&
             data.plots is list &&
             data.kangals is number && data.kangals >= 0;
    }

    function isValidLeaderboard(data) {
      return data.keys().hasAll(['uid', 'displayName', 'score']) &&
             data.uid is string &&
             data.displayName is string &&
             data.score is number;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /gardens/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidGarden(request.resource.data);
      allow update: if isOwner(userId) && isValidGarden(request.resource.data);
    }

    match /leaderboard/{userId} {
      allow read: if true; // Publicly readable
      allow create: if isOwner(userId) && isValidLeaderboard(request.resource.data);
      allow update: if isOwner(userId) && isValidLeaderboard(request.resource.data);
    }
  }
}
